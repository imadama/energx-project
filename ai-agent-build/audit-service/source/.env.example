# API authentication (aanbevolen, anders is je endpoint publiek)
API_KEY=verzin-een-lange-random-string-hier

# PageSpeed Insights API (gratis, via Google Cloud Console)
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Google Search Console (Service Account)
# Pad naar de JSON die je in Cloud Console hebt gemaakt
# Mount via docker-compose: ./credentials/gsc-service-account.json
GSC_SERVICE_ACCOUNT_JSON=/app/credentials/gsc-service-account.json
GSC_SITE_URL=sc-domain:energx.nl

# General
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
USER_AGENT=EnergxAuditBot/1.0 (+https://energx.nl)
